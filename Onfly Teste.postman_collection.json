  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();\r",
                  "pm.environment.set(\"accessToken\", jsonData.access_token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {
              "accept": true
            }
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Request-Id",
                "value": "{{$randomUUID}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"x_api_key\": \"{{xApiKey}}\"\r\n}\r\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "localhost:8080/auth/token",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "token"
              ]
            }
          },
          "response": []
        }
      ]
    },
